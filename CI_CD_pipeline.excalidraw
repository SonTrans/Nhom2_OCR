    {
      "id": "mW3_rB2bS7UUmVtSZpM0r",
      "type": "text",
      "x": -2298.7784722062133,
      "y": 1900.5272789707392,
      "width": 493.32977294921875,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b22",
      "roundness": null,
      "seed": 2050646560,
      "version": 970,
      "versionNonce": 2022903051,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780298606692,
      "link": null,
      "locked": false,
      "text": "danh sách sản phẩm sẽ mua:\n- có thể bấm vào để xem chi tiết thông tin\n- lưu ý bấm thanh toán thì phải đảm bảo tất cả \nsản phẩm đều có thể thanh toán vì nhỡ đâu\nngười mua mới bỏ vào giỏ hàng mà lúc sau nhãn\nhàng lại cho sản phẩm đấy không bán nữa thì\nsẽ conflict\n(nếu nếu bấm thanh toán mà có lỗi phải báo danh \nsách tên những sản phẩm không tồn tại nữa\ncòn nếu được hiện thông báo to ra là \"thanh toán \nthành công\" là được)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "danh sách sản phẩm sẽ mua:\n- có thể bấm vào để xem chi tiết thông tin\n- lưu ý bấm thanh toán thì phải đảm bảo tất cả \nsản phẩm đều có thể thanh toán vì nhỡ đâu\nngười mua mới bỏ vào giỏ hàng mà lúc sau nhãn\nhàng lại cho sản phẩm đấy không bán nữa thì\nsẽ conflict\n(nếu nếu bấm thanh toán mà có lỗi phải báo danh \nsách tên những sản phẩm không tồn tại nữa\ncòn nếu được hiện thông báo to ra là \"thanh toán \nthành công\" là được)",
      "autoResize": true,
      "lineHeight": 1.25
    },
